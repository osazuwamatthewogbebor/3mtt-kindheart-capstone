generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
model User {
  id              String   @id @default(uuid())
  name            String
  email           String   @unique
  password        String
  profile_picture String?
  created_at      DateTime @default(now())
  role            Role     @default(USER)
}

enum Role {
  USER
  ADMIN
}