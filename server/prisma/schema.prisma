generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
model User {
  id              String   @id @default(uuid())
  name            String
  email           String   @unique
  password        String?
  googleId        String?  @unique
  resetToken      String?
  resetTokenExpiry DateTime?
  isVerified      Boolean  @default(false)
  emailVerificationToken String?
  emailVerificationExpiry DateTime?
  profile_picture String?
  profileImageUrl String?
  profileImagePublicId String?
  created_at      DateTime @default(now())
  role            Role     @default(USER)

  campaigns       Campaign[]
  sessions        Session[]
  campaigns       Campaign[]
}

model Campaign {
  id          String   @id @default(uuid())
  userId      String
  title       String
  description String
  goalAmount  Decimal  @db.Decimal(12, 2)
  raisedAmount Decimal @default(0) @db.Decimal(12, 2)
  startDate   DateTime @default(now())
  endDate     DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([startDate])
  @@index([endDate])
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  refreshToken String   @unique
  userAgent    String?
  ipAddress    String?
  createdAt    DateTime @default(now())
  expiresAt    DateTime

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model BlacklistedToken {
  id         String   @id @default(uuid())
  jti        String   @unique
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@index([expiresAt])
}

model Campaign {
  id            String   @id @default(uuid())
  userId        String
  title         String
  description   String
  goalAmount    Decimal  @db.Decimal(12, 2)
  raisedAmount  Decimal  @db.Decimal(12, 2) @default(0)
  startDate     DateTime @default(now())
  endDate       DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([startDate])
  @@index([endDate])
}

enum Role {
  USER
  ADMIN
}